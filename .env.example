# ============================================================
# AI Code Review Bot — Environment Variables
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- GitHub App (Step 2 in README) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=        # base64-encoded PEM file content
GITHUB_WEBHOOK_SECRET=         # generate: openssl rand -hex 32
GITHUB_CLIENT_ID=              # optional — for OAuth login
GITHUB_CLIENT_SECRET=          # optional — for OAuth login

# --- Anthropic (console.anthropic.com) ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
MODEL_NAME=claude-haiku-4-5-20251001   # or claude-sonnet-4-6 for higher quality

# --- Database (Step 3 — Supabase free tier) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# --- Redis (Step 4 — Upstash free tier) ---
REDIS_URL=redis://default:password@xxx.upstash.io:6379

# --- App URLs ---
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Frontend (set in apps/dashboard/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
